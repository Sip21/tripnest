<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Hero Design"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <properties
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Properties"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <heroHeight
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldDescription="Controls the minimum height of the hero section"
                                fieldLabel="Hero Height"
                                name="./heroHeight">
                                <items jcr:primaryType="nt:unstructured">
                                    <full
                                        jcr:primaryType="nt:unstructured"
                                        selected="{Boolean}true"
                                        text="Full Screen (100vh)"
                                        value="full"/>
                                    <large
                                        jcr:primaryType="nt:unstructured"
                                        text="Large (80vh)"
                                        value="large"/>
                                    <medium
                                        jcr:primaryType="nt:unstructured"
                                        text="Medium (60vh)"
                                        value="medium"/>
                                    <small
                                        jcr:primaryType="nt:unstructured"
                                        text="Small (40vh)"
                                        value="small"/>
                                </items>
                            </heroHeight>
                            <textAlign
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldDescription="Align heading and subheading text"
                                fieldLabel="Text Alignment"
                                name="./textAlign">
                                <items jcr:primaryType="nt:unstructured">
                                    <center
                                        jcr:primaryType="nt:unstructured"
                                        selected="{Boolean}true"
                                        text="Center"
                                        value="center"/>
                                    <left
                                        jcr:primaryType="nt:unstructured"
                                        text="Left"
                                        value="left"/>
                                    <right
                                        jcr:primaryType="nt:unstructured"
                                        text="Right"
                                        value="right"/>
                                </items>
                            </textAlign>
                            <overlayOpacity
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldDescription="Dark overlay on top of the background image"
                                fieldLabel="Background Overlay"
                                name="./overlayOpacity">
                                <items jcr:primaryType="nt:unstructured">
                                    <none
                                        jcr:primaryType="nt:unstructured"
                                        text="None"
                                        value="none"/>
                                    <light
                                        jcr:primaryType="nt:unstructured"
                                        text="Light (20%)"
                                        value="light"/>
                                    <medium
                                        jcr:primaryType="nt:unstructured"
                                        selected="{Boolean}true"
                                        text="Medium (40%)"
                                        value="medium"/>
                                    <dark
                                        jcr:primaryType="nt:unstructured"
                                        text="Dark (70%)"
                                        value="dark"/>
                                </items>
                            </overlayOpacity>
                            <showSubheading
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                checked="{Boolean}true"
                                fieldLabel="Show Subheading"
                                name="./showSubheading"
                                text="Display the subheading below the main heading"
                                value="{Boolean}true"/>
                            <showCta
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                checked="{Boolean}true"
                                fieldLabel="Show CTA Button"
                                name="./showCta"
                                text="Display the call-to-action button"
                                value="{Boolean}true"/>
                        </items>
                    </properties>
                    <styletab
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/include"
                        path="/mnt/overlay/cq/gui/components/authoring/dialog/style/tab_design/styletab"/>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
