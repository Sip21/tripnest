#
# This is the default list of hosts that are allowed to invalidate (flush) the cache
# on the dispatcher for the tripnest website.
#

# Contains the AEM backend that is allowed to invalidate the cache on the dispatcher
/0001 {
	/type "deny"
	/glob "*.*.*.*"
}
/0002 {
	/type "allow"
	/glob "172.17.0.1"
}

